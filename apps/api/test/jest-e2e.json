{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "setupFiles": ["./setup-e2e.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1",
    "^.*generated/prisma/(.*)$": "<rootDir>/../generated/prisma/$1",
    "^@/infra/(.*)$": "<rootDir>/../src/infra/$1",
    "^@/modules/(.*)$": "<rootDir>/../src/modules/$1",
    "^@/(.*)$": "<rootDir>/../src/$1"
  }
}
